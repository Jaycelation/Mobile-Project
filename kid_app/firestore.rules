rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function accountDoc() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/accounts/$(request.auth.uid))
        && accountDoc().data.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function ownsChildByProfile(childId) {
      return signedIn()
        && exists(/databases/$(database)/documents/child_profiles/$(childId))
        && get(/databases/$(database)/documents/child_profiles/$(childId)).data.ownerParentId == request.auth.uid;
    }

    function ownsChildByLink(childId) {
      return signedIn()
        && exists(/databases/$(database)/documents/parent_child_links/$(request.auth.uid + "_" + childId));
    }

    function ownsChild(childId) {
      return ownsChildByProfile(childId) || ownsChildByLink(childId);
    }

    match /accounts/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.accountId == userId;
      allow read, update, delete: if isSelf(userId) || isAdmin();
    }

    match /content_catalog/{contentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasRole("teacher");

      match /levels/{levelId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || hasRole("teacher");
      }

      match /detail/{detailId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || hasRole("teacher");
      }

      // Demo only: client vẫn đọc questions. Production nên chấm quiz ở server.
      match /questions/{questionId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || hasRole("teacher");
      }
    }

    match /child_profiles/{childId} {
      allow create: if signedIn()
        && request.resource.data.ownerParentId == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if isAdmin() || ownsChild(childId);

      match /settings/{docId} {
        allow create: if signedIn();
        allow read, update, delete: if isAdmin() || ownsChild(childId);
      }

      match /activity_attempts/{attemptId} {
        allow create: if signedIn();
        allow read, update, delete: if isAdmin() || ownsChild(childId);

        match /answers/{answerId} {
          allow create: if signedIn();
          allow read, update, delete: if isAdmin() || ownsChild(childId);
        }
      }
    }

    match /parent_child_links/{linkId} {
      allow create: if signedIn()
        && request.resource.data.parentId == request.auth.uid;
      allow read: if isAdmin()
        || (signedIn() && resource.data.parentId == request.auth.uid)
        || hasRole("teacher");
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.parentId == request.auth.uid);
    }

    match /child_stats/{childId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if isAdmin() || ownsChild(childId) || hasRole("teacher");
    }

    match /badges/{badgeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasRole("teacher");
    }

    match /child_badges/{badgeDocId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if isAdmin() || hasRole("teacher");
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow create: if hasRole("teacher")
        && request.resource.data.teacherId == request.auth.uid;
      allow update: if isAdmin()
        || (signedIn() && resource.data.teacherId == request.auth.uid)
        || (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["studentCount"]));
      allow delete: if isAdmin()
        || (signedIn() && resource.data.teacherId == request.auth.uid);
    }

    match /class_members/{memberId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin()
        || hasRole("teacher")
        || (signedIn() && resource.data.joinedByParentId == request.auth.uid);
    }

    match /assignments/{assignmentId} {
      allow read: if signedIn();
      allow create: if hasRole("teacher")
        && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.teacherId == request.auth.uid);
    }

    match /assignment_submissions/{submissionId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update, delete: if isAdmin() || hasRole("teacher") || signedIn();
    }

    match /feedback_notes/{feedbackId} {
      allow create: if signedIn();
      allow read: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin() || hasRole("teacher");

      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /leaderboard_snapshots/{snapshotId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || hasRole("teacher");
    }

    match /ai_conversations/{conversationId} {
      allow create: if signedIn()
        && request.resource.data.childId is string;
      allow read, update, delete: if isAdmin()
        || ownsChild(resource.data.childId);

      match /messages/{messageId} {
        allow create: if signedIn();
        allow read, update, delete: if isAdmin()
          || ownsChild(get(/databases/$(database)/documents/ai_conversations/$(conversationId)).data.childId);
      }
    }

    match /posts/{postId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read, create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
