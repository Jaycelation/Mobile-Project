<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- 1. Vòng tròn nền trắng, viền xanh đậm -->
    <path
        android:pathData="M50,50m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0"
        android:strokeWidth="4"
        android:strokeColor="#1B5E20"
        android:fillColor="#FFFFFF"/>

    <!-- 2. Thân quả táo (Đổ bóng từ đỏ tươi sang đỏ đậm) -->
    <path
        android:pathData="M50,35c-15,0 -25,8 -25,25c0,18 12,28 25,28s25,-10 25,-28c0,-17 -10,-25 -25,-25z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="50" android:startY="35"
                android:endX="50" android:endY="88"
                android:type="linear">
                <item android:offset="0" android:color="#FF5252"/>
                <item android:offset="1" android:color="#A00000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Điểm sáng trên quả táo (Tạo hiệu ứng 3D bóng loáng) -->
    <path
        android:pathData="M40,45c-3,0 -6,5 -6,10s3,5 6,5s6,-5 6,-10s-3,-10 -6,-10z"
        android:fillColor="#40FFFFFF"/>

    <!-- 4. Cuống lá -->
    <path
        android:pathData="M50,35c0,-5 3,-8 6,-8"
        android:strokeWidth="3"
        android:strokeColor="#5D4037"
        android:strokeLineCap="round"/>

    <!-- 5. Lá xanh -->
    <path
        android:pathData="M52,32c5,-5 12,-2 12,5c0,5 -7,8 -12,5z"
        android:fillColor="#4CAF50"/>
</vector>
