<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base app theme -->
    <style name="Theme.Kid_app" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary_yellow</item>
        <item name="colorOnSecondary">@color/gray_900</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/status_error</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:windowBackground">@color/bg_main</item>
    </style>

    <!-- Splash / Welcome theme -->
    <style name="Theme.Kid_app.Splash" parent="Theme.Kid_app">
        <!-- Đối với Android 12+, cấu hình icon khởi động hệ thống -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/logo_app</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/white</item>

        <!-- Cấu hình cũ cho Android thấp hơn -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Auth screens -->
    <style name="Theme.Kid_app.Auth" parent="Theme.Kid_app">
        <item name="android:statusBarColor">@color/primary_green_dark</item>
    </style>

    <!-- Child home - bright and fun -->
    <style name="Theme.Kid_app.Child" parent="Theme.Kid_app">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/primary_green</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.Title.Large" parent="">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Title.Medium" parent="">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.Body" parent="">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Button Styles -->
    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_green</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Card Style -->
    <style name="Card.Module" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- Input Style -->
    <style name="InputLayout.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_green</item>
        <item name="hintTextColor">@color/primary_green</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>