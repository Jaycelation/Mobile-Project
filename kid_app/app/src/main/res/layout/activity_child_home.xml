<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header & Profile -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_child_home_header"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_icon_circle"
        android:backgroundTint="#4DFFFFFF"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Avatar bé đã được phóng to (Giống mẫu thầy giáo) -->
    <ImageView
        android:id="@+id/iv_child_avatar"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/hoc_sinh_nam"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_child_greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/quicksand_bold"
        android:text="Chào bé! 👋"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_child_avatar" />

    <TextView
        android:id="@+id/tv_current_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand_bold"
        android:text="Danh hiệu: Mầm Non Chăm Chỉ 🌱"
        android:textColor="#FFEB3B"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_child_greeting" />

    <TextView
        android:id="@+id/tv_today_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/quicksand_medium"
        android:text="Thứ Hai, 13/04/2026"
        android:textColor="#E0F2F1"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_current_badge" />

    <!-- Stats Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_stats"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintBottom_toBottomOf="@id/header_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/tv_total_points" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/secondary_yellow" android:textSize="20sp" android:fontFamily="@font/quicksand_bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ Điểm" android:textSize="12sp" android:fontFamily="@font/quicksand_medium" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="40dp" android:layout_gravity="center" android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/tv_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/secondary_orange" android:textSize="20sp" android:fontFamily="@font/quicksand_bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥 Chuỗi" android:textSize="12sp" android:fontFamily="@font/quicksand_medium" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="40dp" android:layout_gravity="center" android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/tv_completed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/primary_green" android:textSize="22sp" android:fontFamily="@font/quicksand_bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✅ Xong" android:textColor="@color/text_secondary" android:textSize="12sp" android:fontFamily="@font/quicksand_medium" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Content Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
        app:layout_constraintTop_toBottomOf="@id/card_stats">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Assignments Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_assignments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/bg_explanation_box"
                    android:backgroundTint="#E3F2FD">
                    <TextView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_icon_circle" android:backgroundTint="@color/white" android:gravity="center" android:text="📝" android:textSize="22sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bài tập cô giao" android:textColor="@color/primary_green_dark" android:fontFamily="@font/quicksand_bold" android:textSize="16sp" />
                        <TextView android:id="@+id/tv_assignment_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bé có 1 bài tập mới đang chờ!" android:textColor="@color/text_secondary" android:fontFamily="@font/quicksand_medium" android:textSize="12sp" />
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_next" app:tint="@color/gray_500" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Feedback Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_icon_circle" android:backgroundTint="#FFF3E0" android:gravity="center" android:text="✉️" android:textSize="22sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lời nhắn từ cô giáo" android:textColor="@color/primary_green_dark" android:fontFamily="@font/quicksand_bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bé nhấn vào đây để xem cô nhận xét nhé!" android:textColor="@color/text_secondary" android:fontFamily="@font/quicksand_medium" android:textSize="12sp" />
                    </LinearLayout>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_next" app:tint="@color/gray_500" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Portals -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_learning_portal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#AD1457">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🗓️" android:textSize="50sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="HỌC TẬP" android:textColor="@color/white" android:textSize="20sp" android:fontFamily="@font/quicksand_bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_practice_portal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#EF6C00">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▶️" android:textSize="50sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="THỰC HÀNH" android:textColor="@color/white" android:textSize="20sp" android:fontFamily="@font/quicksand_bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- AI Chat Bot FAB -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fab_ai_chat"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="32.5dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_container"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖"
            android:textSize="38sp" />
    </androidx.cardview.widget.CardView>

    <!-- THANH ĐIỀU HƯỚNG MỚI (PHONG CÁCH GIÁO VIÊN) -->
    <LinearLayout
        android:id="@+id/bottom_navigation_container"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@drawable/bg_bottom_nav_bar"
        android:elevation="15dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_nav_item_selected"
            android:paddingVertical="8dp"
            android:layout_marginHorizontal="4dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="26sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_bold" android:text="Trang chủ" android:textColor="@color/primary_green_dark" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_community"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏆" android:textSize="26sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_medium" android:text="Xếp hạng" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_progress"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📈" android:textSize="26sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_medium" android:text="Tiến độ" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎒" android:textSize="26sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_medium" android:text="Hồ sơ" android:textColor="@color/text_secondary" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>