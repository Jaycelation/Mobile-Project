<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_soft_green"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_parent_list_container"
                android:backgroundTint="@color/white"
                android:src="@drawable/ic_back"
                app:tint="@color/primary_green_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/quicksand_bold"
                android:text="Chi tiết lớp"
                android:textColor="@color/primary_green_dark"
                android:textSize="24sp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_class_detail_icon"
                android:layout_width="120dp"
                android:layout_height="100dp"
                android:src="@drawable/icon_ngoi_truong"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/tv_class_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/quicksand_bold"
                android:text="Lớp Gấu Con 🐻"
                android:textColor="@color/primary_green_dark"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/tv_teacher_class_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/quicksand_medium"
                android:text="Giáo viên: Thanh Kiên  Tổng cộng 25 học sinh"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btn_add_student"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Stat 1: Bài tập đang mở -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                app:cardCornerRadius="35dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:fontFamily="@font/quicksand_bold" android:text="📚 Bài tập đang mở" android:textColor="@color/text_primary" android:textSize="16sp"/>
                    <TextView android:id="@+id/tv_open_assignments_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:fontFamily="@font/quicksand_bold" android:text="0" android:textColor="@color/text_primary" android:textSize="28sp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat 2: Học sinh đã làm bài -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                app:cardCornerRadius="35dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:fontFamily="@font/quicksand_bold" android:text="✅ Học sinh đã làm bài" android:textColor="@color/text_primary" android:textSize="16sp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:gravity="end" android:orientation="vertical">
                        <TextView android:id="@+id/tv_completed_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_bold" android:text="0/0" android:textColor="@color/text_primary" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_medium" android:text="học sinh" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat 3: Học sinh chưa hoàn thành -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                app:cardCornerRadius="35dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:fontFamily="@font/quicksand_bold" android:text="⚠️ Học sinh chưa hoàn thành" android:textColor="@color/text_primary" android:textSize="16sp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:gravity="end" android:orientation="vertical">
                        <TextView android:id="@+id/tv_pending_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_bold" android:text="0" android:textColor="@color/secondary_orange" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/quicksand_medium" android:text="cần chú ý" android:textSize="10sp" android:textColor="@color/secondary_orange"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Search Area -->
            <EditText
                android:id="@+id/et_search_student"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_parent_list_container"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/quicksand_medium"
                android:hint="🔍 Tìm học sinh..."
                android:paddingHorizontal="20dp"
                android:textSize="14sp" />

            <!-- Student List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_students"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_student_in_class" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Add Student Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_student"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:backgroundTint="@color/primary_green"
        android:fontFamily="@font/quicksand_bold"
        android:text="+ THÊM HỌC SINH"
        android:textSize="18sp"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>