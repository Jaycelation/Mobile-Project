<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layout_game_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:src="@drawable/ic_back"
            android:contentDescription="Quay lại"
            app:tint="@color/primary_green_dark" />

        <TextView
            android:id="@+id/tv_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_explanation_box"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:text="Màn 1"
            android:textColor="@color/primary_green_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_explanation_box"
            android:backgroundTint="@color/secondary_yellow"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="00:15"
                android:textColor="@color/primary_green_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Main Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_game_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_explanation_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chạm nhanh vào:"
                    android:textColor="@color/primary_green_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_target_icon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:text="🐸"
                    android:textSize="24sp" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/game_grid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:columnCount="3"
                android:padding="8dp"
                android:rowCount="3">

                <!-- Đảm bảo tạo đủ 9 ô với ID chuẩn -->
                <FrameLayout android:id="@+id/item_0" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_1" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_2" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_3" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_4" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_5" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_6" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_7" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>
                <FrameLayout android:id="@+id/item_8" android:layout_width="85dp" android:layout_height="85dp" android:layout_margin="4dp" android:background="@drawable/bg_card_rounded"><TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="" android:textSize="32sp"/></FrameLayout>

            </GridLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_app_logo" android:contentDescription="Mascot"/>
        <TextView android:id="@+id/tv_footer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_explanation_box" android:padding="8dp" android:text="Nhanh tay lên bé ơi!" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Feedback View -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_feedback_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            app:cardCornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView android:id="@+id/tv_feedback_emoji" android:layout_width="80dp" android:layout_height="80dp" android:background="@drawable/bg_icon_circle" android:gravity="center" android:text="⚡" android:textSize="40sp" />
                <TextView android:id="@+id/tv_feedback_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Tuyệt vời!" android:textColor="@color/status_success" android:textSize="28sp" android:textStyle="bold" />
                <Button android:id="@+id/btn_next" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="24dp" android:text="HOÀN THÀNH" app:cornerRadius="20dp" android:backgroundTint="@color/status_success"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
