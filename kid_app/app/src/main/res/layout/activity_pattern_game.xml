<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- GAME VIEW -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_game_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/layout_game_header"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_icon_circle"
                android:src="@drawable/ic_back"
                app:tint="@color/primary_green_dark" />

            <TextView
                android:id="@+id/tv_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_explanation_box"
                android:paddingHorizontal="24dp"
                android:paddingVertical="8dp"
                android:text="Cấp độ 1"
                android:textColor="@color/primary_green_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/secondary_yellow"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳" android:textSize="16sp" />
                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="00:00"
                    android:textColor="@color/primary_green_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Game Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toTopOf="@id/layout_mascot"
            app:layout_constraintTop_toBottomOf="@id/layout_game_header">

            <TextView
                android:id="@+id/tv_game_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dãy hình thiếu gì?"
                android:textColor="@color/primary_green_dark"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Main Question Area -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iv_pattern_1"
                        android:layout_width="85dp"
                        android:layout_height="110dp"
                        android:layout_margin="4dp"
                        android:scaleType="centerInside"
                        android:padding="5dp" />

                    <ImageView
                        android:id="@+id/iv_pattern_2"
                        android:layout_width="85dp"
                        android:layout_height="110dp"
                        android:layout_margin="4dp"
                        android:scaleType="centerInside"
                        android:padding="5dp" />

                    <ImageView
                        android:id="@+id/iv_pattern_3"
                        android:layout_width="85dp"
                        android:layout_height="110dp"
                        android:layout_margin="4dp"
                        android:scaleType="centerInside"
                        android:padding="5dp" />

                    <FrameLayout
                        android:layout_width="85dp"
                        android:layout_height="110dp"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_pattern_item_missing">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="?"
                            android:textColor="@color/status_error"
                            android:textSize="36sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Choices Area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Bé hãy chọn đáp án đúng nhé:"
                android:textColor="@color/primary_green_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_choice_1"
                    android:layout_width="90dp"
                    android:layout_height="120dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_pattern_item_blue"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:elevation="4dp" />

                <ImageButton
                    android:id="@+id/btn_choice_2"
                    android:layout_width="90dp"
                    android:layout_height="120dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_pattern_item_green"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:elevation="4dp" />

                <ImageButton
                    android:id="@+id/btn_choice_3"
                    android:layout_width="90dp"
                    android:layout_height="120dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_pattern_item_yellow"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:elevation="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Footer Mascot -->
        <LinearLayout
            android:id="@+id/layout_mascot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_app_logo" />
            <TextView
                android:id="@+id/tv_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_explanation_box"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Bé hãy quan sát quy luật nhé! ✨"
                android:textColor="@color/primary_green_dark"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- FEEDBACK OVERLAY (Giữ nguyên logic nhưng cho bo góc tròn hơn) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_feedback_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            app:cardCornerRadius="35dp"
            app:cardElevation="15dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">
                <TextView
                    android:id="@+id/tv_feedback_emoji"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:text="😊"
                    android:textSize="50sp" />
                <TextView
                    android:id="@+id/tv_feedback_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Tuyệt vời!"
                    android:textColor="@color/status_success"
                    android:textSize="30sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_explanation_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_explanation_box"
                    android:padding="16dp"
                    android:text="..."
                    android:textAlignment="center"
                    android:textColor="@color/text_primary" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/status_error"
                    android:text="LÀM LẠI"
                    android:visibility="gone"
                    app:cornerRadius="25dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_level"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/status_success"
                    android:text="TIẾP TỤC"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
