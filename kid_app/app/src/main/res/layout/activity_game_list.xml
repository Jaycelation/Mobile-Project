<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layout_game_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:src="@drawable/ic_back"
            app:tint="@color/primary_green_dark" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_explanation_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Mini-games"
                android:textColor="@color/primary_green_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_home"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:src="@drawable/ic_home"
            app:tint="@color/primary_green_dark" />
    </RelativeLayout>

    <!-- Dùng ScrollView để bắt sự kiện cuộn tốt hơn trên giả lập -->
    <ScrollView
        android:id="@+id/scroll_view_games"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarSize="4dp"
        android:scrollbarThumbVertical="@color/primary_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_game_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="120dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn 1 trò chơi"
                android:textColor="@color/primary_green_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- 1. Thử thách con số -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_number"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/secondary_yellow"
                    android:gravity="center"
                    android:text="🔢"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_number"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thử thách con số"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn đúng số cô yêu cầu"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 10. Đếm số quả -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_counting_fruit"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#009688"
                    android:gravity="center"
                    android:text="🍓"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_counting_fruit"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đếm số quả"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé hãy đếm xem bao nhiêu quả nhé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_counting_fruit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 2. Ghép hình bóng -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_shadow"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/accent_purple"
                    android:gravity="center"
                    android:text="🎯"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_shadow"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ghép hình bóng"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kéo hình vào đúng vị trí"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_shadow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 3. Đúng con vật -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_animal"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/accent_pink"
                    android:gravity="center"
                    android:text="🦁"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_animal"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đúng con vật"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé hãy chọn đúng hình nhé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_animal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 9. Đúng chữ cái -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_alphabet_match"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="#AD1457"
                    android:gravity="center"
                    android:text="🔤"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_alphabet_match"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đúng chữ cái"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé hãy chọn đúng chữ nhé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_alphabet_match"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 7. Đúng loại quả -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_fruit"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/secondary_orange"
                    android:gravity="center"
                    android:text="🍎"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_fruit"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đúng loại quả"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé hãy chọn đúng loại quả nhé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_fruit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 8. Đúng màu sắc -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_color_match"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/accent_blue"
                    android:gravity="center"
                    android:text="🎨"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_color_match"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đúng màu sắc"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bé hãy chọn đúng màu nhé"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_color_match"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 4. Quy luật -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_pattern"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/status_success"
                    android:gravity="center"
                    android:text="🧩"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_pattern"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quy luật"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tìm hình tiếp theo"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_pattern"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 5. Nhanh tay -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_fast"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/accent_blue"
                    android:gravity="center"
                    android:text="👀"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_fast"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhanh tay"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thử thách tinh mắt"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_fast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

            <!-- 6. Ghép tranh -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:elevation="2dp"
                android:padding="12dp">
                <TextView
                    android:id="@+id/icon_game_puzzle"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_avatar_circle"
                    android:backgroundTint="@color/accent_purple"
                    android:gravity="center"
                    android:text="🖼️"
                    android:textSize="26sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:layout_toEndOf="@id/icon_game_puzzle"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ghép tranh"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xếp hình hoàn chỉnh"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play_puzzle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/primary_green"
                    android:text="CHƠI"
                    android:textStyle="bold"
                    app:cornerRadius="20dp" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
