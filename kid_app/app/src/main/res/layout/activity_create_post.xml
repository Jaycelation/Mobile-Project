<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:backgroundTint="#FFEBEE"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/status_error" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khoe Ảnh Mới"
                android:textColor="@color/primary_green_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📸"
                android:textSize="18sp" />
        </LinearLayout>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btn_submit_post"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Image Preview Area -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/secondary_yellow_light">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/iv_post_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="32dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/primary_green_dark" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_change_image"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="16dp"
                        android:backgroundTint="@color/white"
                        android:text="🔄 Đổi ảnh"
                        android:textAllCaps="false"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/primary_green_dark"
                        app:strokeWidth="1dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Caption Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Nói gì đó về bức ảnh này nào:"
                android:textColor="@color/primary_green_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_post_content"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_explanation_box"
                android:backgroundTint="@color/white"
                android:gravity="top"
                android:hint="Ví dụ: Bức tranh em tự vẽ nè! 🥰"
                android:padding="16dp"
                android:textSize="14sp" />

            <!-- Mood Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Bé đang cảm thấy:"
                android:textColor="@color/primary_green_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_mood_happy"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/secondary_yellow"
                    android:gravity="center"
                    android:text="😀"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/btn_mood_cool"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:text="😎"
                    android:textSize="24sp"
                    app:strokeColor="@color/gray_300"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/btn_mood_love"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_icon_circle"
                    android:backgroundTint="@color/white"
                    android:gravity="center"
                    android:text="😍"
                    android:textSize="24sp"
                    app:strokeColor="@color/gray_300"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_post"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:backgroundTint="@color/secondary_orange"
        android:text="🚀 ĐĂNG LÊN BẢNG TIN"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
