<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layout_game_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:src="@drawable/ic_back"
            app:tint="@color/primary_green_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_explanation_box"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:text="Hình học logic"
            android:textColor="@color/primary_green_dark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_game_header">

        <TextView
            android:id="@+id/tv_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bé hãy chạm vào hình nhé! ✨"
            android:textColor="@color/text_secondary"
            android:textSize="20sp"
            android:layout_marginBottom="40dp"/>

        <!-- Thẻ hình học -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_shape_main"
            android:layout_width="280dp"
            android:layout_height="320dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/iv_shape_display"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/shape_red_circle" />

                <TextView
                    android:id="@+id/tv_shape_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Hình Tròn"
                    android:textColor="@color/primary_green_dark"
                    android:textStyle="bold"
                    android:textSize="28sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_progress_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Hình 1 / 4"
            android:textColor="@color/primary_green_dark"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
