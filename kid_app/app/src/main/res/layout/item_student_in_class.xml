<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_explanation_box"
        android:backgroundTint="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_student_avatar"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@mipmap/ic_launcher"
            app:civ_border_color="@color/primary_green_soft"
            app:civ_border_width="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Minh Anh (Miu)"
                android:textColor="@color/primary_green_dark"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_parent_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phụ huynh: Chị Lan"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="✅ Đã hoàn thành bài tập"
                android:textColor="@color/status_success"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_student_action"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/bg_icon_circle"
            android:backgroundTint="#F0F0F0"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/primary_green_dark" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
