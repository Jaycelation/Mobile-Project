<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layout_game_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:src="@drawable/ic_back"
            app:tint="@color/primary_green_dark"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tv_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_explanation_box"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:text="Ghép hình"
            android:textColor="@color/primary_green_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_icon_circle"
            android:gravity="center"
            android:minWidth="45dp"
            android:minHeight="45dp"
            android:text="00"
            android:textColor="@color/primary_green_dark"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Main Game Area -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_game_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_explanation_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tìm mảnh ghép còn thiếu"
                android:textColor="@color/primary_green_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Puzzle Target (Halves) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_left_half"
                    android:layout_width="80dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_fruit_apple_left"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/iv_right_placeholder"
                    android:layout_width="80dp"
                    android:layout_height="160dp"
                    android:background="@drawable/bg_pattern_item_missing"
                    android:padding="20dp"
                    android:alpha="0.5"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Chọn mảnh ghép đúng:"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <!-- Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_option_1"
                    android:layout_width="70dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_explanation_box"
                    android:scaleType="fitCenter"
                    android:padding="10dp"
                    android:elevation="2dp" />

                <ImageButton
                    android:id="@+id/btn_option_2"
                    android:layout_width="70dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_explanation_box"
                    android:scaleType="fitCenter"
                    android:padding="10dp"
                    android:elevation="2dp" />

                <ImageButton
                    android:id="@+id/btn_option_3"
                    android:layout_width="70dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_explanation_box"
                    android:scaleType="fitCenter"
                    android:padding="10dp"
                    android:elevation="2dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Feedback -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_feedback_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            app:cardCornerRadius="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:id="@+id/tv_feedback_emoji"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:text="🎨"
                    android:textSize="40sp" />
                <TextView
                    android:id="@+id/tv_feedback_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Đẹp Quá!"
                    android:textColor="@color/status_success"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_feedback_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Bé đã ghép thành công bức tranh rồi!"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_retry"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="@color/status_error"
                    android:text="Làm Lại Nhé 🔄"
                    android:visibility="gone"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:text="TIẾP THEO"
                    android:backgroundTint="@color/status_success"
                    app:cornerRadius="20dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
